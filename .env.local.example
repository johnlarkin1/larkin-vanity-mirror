# Client-side Google Analytics (for tracking THIS dashboard)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Analytics (shared service account for all GA properties)
GOOGLE_SERVICE_ACCOUNT_KEY=

# Blog - GA4
BLOG_GA_PROPERTY_ID=

# Walk in the Parquet - GA4 (same service account as blog)
WALK_IN_THE_PARQUET_GA_PROPERTY_ID=

# Vanity Mirror Dashboard - GA4 property for this dashboard itself
VANITY_MIRROR_GA_PROPERTY_ID=

# App Store Connect API (shared credentials across apps; per-app IDs below)
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_PRIVATE_KEY=                       # Base64-encoded .p8 file
APP_STORE_CONNECT_VENDOR_NUMBER=
WALK_IN_THE_PARQUET_APP_STORE_CONNECT_APP_ID=        # Walk in the Parquet Apple ID
ODOZI_APP_STORE_CONNECT_APP_ID=                      # Odozi Apple ID (from App Store URL)

# PostHog — one shared personal API key, per-project IDs
POSTHOG_API_KEY=                              # Personal API key (phx_...) with read access to all projects
# POSTHOG_HOST=https://us.posthog.com        # Optional: defaults to US cloud

# PostHog project IDs (numeric, from URL: us.posthog.com/project/<ID>/)
TENNIS_SCORIGAMI_POSTHOG_PROJECT_ID=
ODOZI_POSTHOG_PROJECT_ID=
AFUERA_POSTHOG_PROJECT_ID=
BE_RIGHT_BACK_POSTHOG_PROJECT_ID=

# GitHub repos for release/version tracking
ODOZI_GITHUB_REPO=johnlarkin1/odozi
AFUERA_GITHUB_REPO=johnlarkin1/afuera
BE_RIGHT_BACK_GITHUB_REPO=johnlarkin1/be-right-back

# Supabase (for Scrollz)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# GitHub (for repository star tracking)
GITHUB_USERNAME=johnlarkin1
GITHUB_TOKEN=  # Optional but recommended (60 vs 5000 requests/hour)
GITHUB_EXCLUDE_REPOS=              # Comma-separated repo names to hide (e.g., repo1,repo2)

# Canny (for Scrollz notifications)
CANNY_API_KEY=

# Published Packages (comma-separated package names)
NPM_PACKAGES=                    # e.g., package1,@scope/package2
PYPI_PACKAGES=                   # e.g., walk-in-the-parquet
CRATES_PACKAGES=                 # e.g., my-crate

# YouTube (for video analytics)
YOUTUBE_API_KEY=                 # YouTube Data API v3 key (create in GCP console)
YOUTUBE_CHANNEL_ID=              # Your YouTube channel ID
